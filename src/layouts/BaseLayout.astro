---
import '../styles/global.css';
import '@fontsource/fraunces/300'
import '@fontsource/inter/400'
import '@fontsource/inter/300'
import '@fontsource/dm-mono/400'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import Analytics from '@vercel/analytics/astro'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'floating.is',
  description = 'An independed software studio.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      // Avoid FOUC: set theme class before paint
      const stored=localStorage.getItem('theme')
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark')
      }
    </script>
    <meta property="og:image" content="https://floating.is/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="floating.is" />
    <meta
      property="og:description"
      content="Quiet software built slowly and maintained for the long term."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://floating.is/og.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://use.typekit.net/ctp2ldn.css">
  </head>
  <body class="min-h-dvh bg-bg text-ink antialiased">
    <SiteHeader />
    <slot />
    <SiteFooter />
    <Analytics />
  </body>
</html>
