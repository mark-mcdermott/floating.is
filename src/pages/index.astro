---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout>
  <main>
    <section class="mx-auto max-w-7xl px-6 pt-12 md:px-8 md:pt-20">
      <div class="md:grid md:grid-cols-[260px_1fr] md:items-start md:gap-20">

        <div>
          <p class="font-serif text-8xl leading-none tracking-tight text-ink">
            01<span class="text-accent">.</span>
          </p>
          <div class="mt-5 w-10 border-t border-ink/20"></div>
        </div>

        <h1 class="mt-10 font-serif text-5xl leading-[1.08] tracking-tight text-ink md:mt-0 md:text-6xl lg:text-7xl">
          Software that <em class="italic text-muted">hovers</em> just above the day.
        </h1>

      </div>

      <div class="mt-20 border-t border-bloack/10 dark:border-white/10 md:mt-28"></div>
    </section>
  </main>
</BaseLayout>
